{
  "name": "jobsentinel",
  "version": "2.9.1",
  "description": "Privacy-preserving local-first job-search assistant for desktop",
  "type": "module",
  "packageManager": "npm@11.17.0",
  "scripts": {
    "dev": "vite",
    "dev:mock": "VITE_MOCK_API=true vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "lint:md": "markdownlint --config .markdownlint.json --ignore node_modules --ignore dist --ignore target --ignore src-tauri/gen --ignore .vale/styles --ignore CHANGELOG.md --ignore docs/CLAUDE.md --ignore .claude --ignore docs/archive --ignore src-tauri/target --ignore browser-extension --ignore playwright-report --ignore test-results \"**/*.md\"",
    "lint:md:fix": "markdownlint --fix --config .markdownlint.json --ignore node_modules --ignore dist --ignore target --ignore src-tauri/gen --ignore .vale/styles --ignore CHANGELOG.md --ignore docs/CLAUDE.md --ignore .claude --ignore docs/archive --ignore src-tauri/target --ignore browser-extension --ignore playwright-report --ignore test-results \"**/*.md\"",
    "lint:prose": "node scripts/run-vale-docs.mjs",
    "lint:prose:all": "vale .",
    "lint:architecture": "node scripts/check-frontend-boundaries.mjs",
    "lint:security": "node scripts/check-security-sensors.mjs && npm run lint:secrets",
    "lint:secrets": "node scripts/check-secrets.mjs",
    "lint:bloat": "node scripts/check-repo-bloat.mjs",
    "lint:dup": "node scripts/check-duplication.mjs",
    "lint:external-ai": "node scripts/check-external-ai-gateway.mjs",
    "lint:deps": "node scripts/check-dependency-pins.mjs",
    "lint:deps:why": "node scripts/check-dependency-rationale.mjs",
    "lint:actions": "node scripts/check-action-pins.mjs",
    "lint:skills": "node scripts/check-agent-skills.mjs",
    "lint:tauri-invokes": "node scripts/check-tauri-invokes.mjs",
    "lint:tests": "node scripts/check-test-quality.mjs",
    "harness:check": "node scripts/check-harness.mjs",
    "harness:benchmark": "node scripts/harness-benchmark.mjs",
    "harness:plan": "node scripts/harness-plan.mjs",
    "harness:session": "node scripts/harness-session.mjs",
    "harness:score": "node scripts/harness-score.mjs",
    "macos:readiness": "node scripts/check-macos-readiness.mjs",
    "doctor": "node scripts/doctor.mjs",
    "doctor:e2e": "node scripts/doctor.mjs --e2e",
    "release:check-version": "node scripts/validate-release-version.mjs",
    "release:check-deps": "node scripts/check-dependency-pins.mjs --latest && node scripts/check-action-pins.mjs --latest",
    "release:check-env": "node scripts/check-release-environment.mjs",
    "release:readiness": "node scripts/check-release-readiness.mjs",
    "release:sbom": "node scripts/generate-release-sbom.mjs",
    "release:skills": "node scripts/package-agent-skills.mjs",
    "release:verify:public": "node scripts/verify-public-release-assets.mjs",
    "lint:harness": "npm run harness:check",
    "lint:docs": "npm run harness:check && npm run lint:md && npm run lint:prose",
    "test": "vitest",
    "test:run": "vitest run",
    "test:scripts": "node --test \"scripts/tests/*.test.mjs\" \"scripts/security/tests/*.test.mjs\"",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node scripts/run-playwright.mjs test --project=chromium",
    "test:e2e:smoke": "node scripts/run-playwright.mjs test --project=chromium --grep @smoke",
    "test:e2e:smoke:budget": "node scripts/e2e-budget.mjs --max-duration-ms 30000 --max-tests 25 -- test --project=chromium --grep @smoke",
    "test:e2e:smoke:all": "node scripts/run-playwright.mjs test --grep @smoke",
    "test:e2e:all:budget": "node scripts/e2e-budget.mjs --max-duration-ms 240000 --max-tests 320 -- test",
    "test:e2e:last-failed": "node scripts/run-playwright.mjs test --last-failed",
    "test:e2e:all": "node scripts/run-playwright.mjs test",
    "test:e2e:ui": "node scripts/run-playwright.mjs test --project=chromium --ui",
    "test:e2e:headed": "node scripts/run-playwright.mjs test --project=chromium --headed",
    "test:e2e:ci": "node scripts/run-playwright.mjs test",
    "docs:screenshots": "node scripts/update-doc-screenshots.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:linux-appimage": "node scripts/build-linux-appimage.mjs",
    "tauri:build:macos": "node scripts/build-macos-dmg.mjs",
    "tauri:verify:macos": "node scripts/verify-macos-package.mjs",
    "tauri:verify:macos:latest": "node scripts/verify-latest-macos-release.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-notification": "2.3.3",
    "dompurify": "3.4.11",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-window": "2.2.7",
    "recharts": "3.9.0",
    "web-vitals": "5.3.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-onboarding": "10.4.6",
    "@storybook/addon-vitest": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@tailwindcss/vite": "4.3.1",
    "@tauri-apps/cli": "2.11.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "autoprefixer": "10.5.1",
    "eslint": "10.5.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-storybook": "10.4.6",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.8",
    "markdownlint-cli": "0.49.0",
    "postcss": "8.5.15",
    "storybook": "10.4.6",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  },
  "overrides": {
    "semver": "7.8.5",
    "@reduxjs/toolkit": {
      "reselect": "5.2.0"
    },
    "@testing-library/jest-dom": {
      "aria-query": "5.3.2"
    }
  }
}

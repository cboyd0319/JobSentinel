{
  "schema": "jobsentinel.file_size_contract.v3",
  "projection_of": "scripts/harness/contracts/repository-structure.json",
  "baseline": {
    "measured_on": "2026-07-14",
    "owner": "repository maintainers",
    "method": "Tracked and untracked nonignored source and configuration; physical lines and raw bytes."
  },
  "coverage": {
    "extensions": [
      ".cs", ".csproj", ".cjs", ".css", ".hcl", ".js", ".json", ".jsx",
      ".mjs", ".php", ".props", ".ps1", ".py", ".rs", ".sh", ".slnx",
      ".sql", ".targets", ".tf", ".tfvars", ".toml", ".ts", ".tsx",
      ".yaml", ".yml"
    ],
    "filenames": []
  },
  "scopes": [
    {
      "id": "frontend-source",
      "globs": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.css"],
      "max_lines": 500,
      "max_bytes": 65536,
      "max_line_bytes": 65536
    },
    {
      "id": "end-to-end-tests",
      "globs": ["tests/**/*.ts", "tests/**/*.tsx"],
      "max_lines": 500,
      "max_bytes": 65536,
      "max_line_bytes": 65536
    },
    {
      "id": "rust-source",
      "globs": ["src-tauri/**/*.rs", "crates/**/*.rs"],
      "max_lines": 500,
      "max_bytes": 65536,
      "max_line_bytes": 65536
    },
    {
      "id": "scripts",
      "globs": ["scripts/**/*.mjs", "scripts/**/*.js", "scripts/**/*.sh", "scripts/**/*.ps1"],
      "max_lines": 500,
      "max_bytes": 65536,
      "max_line_bytes": 65536
    },
    {
      "id": "workflows-and-config",
      "globs": [
        "*.json", "*.toml", "*.yml", "*.yaml", "*.js", "*.ts", ".cargo/**",
        ".github/**/*.yml", ".github/**/*.yaml", ".storybook/**", "config/**",
        "scripts/harness/**/*.json", "crates/**/Cargo.toml", "src-tauri/**/*.json",
        "src-tauri/**/*.toml", "skills/**/*.yaml", "skills/**/*.json"
      ],
      "max_lines": 500,
      "max_bytes": 65536,
      "max_line_bytes": 65536
    },
    {
      "id": "database-migrations",
      "globs": ["crates/**/migrations/**/*.sql", "src-tauri/migrations/**/*.sql"],
      "max_lines": 500,
      "max_bytes": 65536,
      "max_line_bytes": 65536
    },
    {
      "id": "resources-and-skill-assets",
      "globs": ["resources/**", "skills/**/assets/**", "public/**"],
      "max_lines": 500,
      "max_bytes": 65536,
      "max_line_bytes": 65536
    },
    {
      "id": "maintained-source-fallback",
      "globs": ["**/*"],
      "max_lines": 500,
      "max_bytes": 65536,
      "max_line_bytes": 65536
    }
  ],
  "coverage_exclusions": [],
  "exceptions": []
}

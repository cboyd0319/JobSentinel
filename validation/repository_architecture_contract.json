  "modularization": {
    "rule": "Use a private module until independent runtime, dependency, release, or security ownership justifies a crate.",
    "forbidden_path_patterns": [
      {
        "pattern": "(^|/)more\\.(js|mjs|rs|ts|tsx)$",
        "reason": "Split files by behavior or aggregate owner, never by a catch-all continuation name."
      },
      {
        "pattern": "(^|/)part[0-9]+\\.(js|mjs|rs|ts|tsx)$",
        "reason": "Split files by behavior or aggregate owner, never by numbered parts."
      },
      {
        "pattern": "/tests/tests/",
        "reason": "Tests have one behavior owner and must not use nested catch-all test directories."
      }
    ]
  }
